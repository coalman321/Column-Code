menu "Column Firmware Configuration"

    config WIFI_SSID
        string "WiFi SSID"
        default "myssid"
        help
            SSID of the WiFi network to connect to.

    config WIFI_PASSWORD
        string "WiFi Password"
        default "mypassword"
        help
            Password for the WiFi network.

    config SERVER_BASE_URL
        string "HTTP Server Base URL"
        default "http://192.168.1.1:8000"
        help
            Base URL of the HTTP server (e.g. http://192.168.1.100:8000).

    config HTTP_POLL_INTERVAL_MS
        int "HTTP poll interval (ms)"
        default 5000
        range 1000 60000
        help
            How often to send an HTTP request to the server, in milliseconds.

    config SERVER_TIMEOUT_MINUTES
        int "Server unreachable timeout (minutes)"
        default 10
        range 1 60
        help
            How long to keep retrying the server before entering light sleep.

    config WAKEUP_GPIO_PIN
        int "Wakeup GPIO pin"
        default 9
        range 0 30
        help
            GPIO pin that wakes the device from light sleep. Pin 9 is the BOOT
            button on most ESP32-C6 devkits.

    config WAKEUP_GPIO_ACTIVE_LOW
        bool "Wakeup GPIO is active low"
        default y
        help
            Enable if the wakeup pin is pulled high and driven low to trigger
            (e.g. a button to GND with internal pull-up). Disable for active high.

    config HEARTBEAT_INTERVAL_SECONDS
        int "Heartbeat interval (seconds)"
        default 30
        range 5 3600
        help
            How often the device posts its MAC to /clients/heartbeat to signal
            it is online. The server marks a client offline after 120 seconds
            of no heartbeat.

    config OTA_CHECK_INTERVAL_MINUTES
        int "OTA check interval (minutes)"
        default 60
        range 1 1440
        help
            How often to compare the running firmware hash with the server and
            apply an update if they differ.

    config COLOR_POLL_INTERVAL_SECONDS
        int "Color poll interval (seconds)"
        default 5
        range 1 3600
        help
            How often the device polls /colors/{mac} from the server and
            drives the SK6812 LEDs with the result.

    config COLOR_GPIO_DATA
        int "GPIO for SK6812 data line"
        default 4
        range 0 30
        help
            GPIO pin connected to the DIN pin of the first SK6812 LED.

    config COLOR_NUM_LEDS
        int "Number of SK6812 LEDs"
        default 4
        range 1 256
        help
            Number of SK6812 RGBW LEDs in the chain.

endmenu
